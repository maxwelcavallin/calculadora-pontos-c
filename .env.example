# Google Tag Manager — único responsável por repassar eventos para o Meta
# (Pixel/CAPI configurados dentro do próprio container GTM, não no código da página)
NEXT_PUBLIC_GTM_ID=

# CRM (Pipe) — webhook server-only, nunca expor com NEXT_PUBLIC_
PIPE_WEBHOOK_URL=

# WhatsApp oficial da Viagente — mesmo número usado nas outras páginas do funil
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999

# Agenda embutida (opcional). Se vazio, a tela de resultado mostra só o botão de WhatsApp.
NEXT_PUBLIC_YCBM_DOMAIN=
